# Klaviyo SMS signup configuration
# Copy this file to ".env" and fill in your values. All VITE_* vars are
# exposed to the browser at build time, so only put PUBLIC values here.

# Klaviyo public API key — also called your "Site ID" / company_id.
# Find it in Klaviyo: Settings > API keys (the 6-character public key).
# This is safe to expose in client-side code.
VITE_KLAVIYO_PUBLIC_KEY=

# The Klaviyo list ID that phone numbers should be subscribed to for SMS.
# Find it in Klaviyo: Audience > Lists & Segments > (your list) > Settings.
VITE_KLAVIYO_SMS_LIST_ID=

# (Optional) Klaviyo API revision date. Leave as-is unless you need a newer one.
VITE_KLAVIYO_REVISION=2025-10-15
